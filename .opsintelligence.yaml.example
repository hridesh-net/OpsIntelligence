# OpsIntelligence Configuration Example
#
# Copy this file to ~/.opsintelligence/opsintelligence.yaml and customize.
# OpsIntelligence is a DevOps-focused autonomous agent:
# PR review, Sonar triage, CI/CD monitoring, incident support, runbooks.

version: 1

# Base directory for memory, tools, skills, and team rules.
state_dir: "~/.opsintelligence"

# Gateway settings (REST/WebSocket server — the only non-Slack surface).
gateway:
  host: "127.0.0.1"
  port: 18789
  token: "${OPSINTEL_GATEWAY_TOKEN}" # set in env, never commit a real token

# Agent execution settings
agent:
  max_iterations: 64
  system_prompt_ext: "" # Extra instructions appended to the global prompt
  # Directory of lazy-loaded markdown skills (INDEX + nodes).
  # Seed with `cp -R <repo>/skills ~/.opsintelligence/` after first install.
  skills_dir: "~/.opsintelligence/skills"
  tools_dir: "~/.opsintelligence/tools"

# ─────────────────────────────────────────────
# DevOps platform integrations (first-class)
# ─────────────────────────────────────────────
# Tokens live in env vars referenced by `token_env:`. Never paste real
# secrets into this file.
devops:
  github:
    enabled: true
    base_url: "https://api.github.com" # override for GitHub Enterprise
    token_env: "OPSINTEL_GITHUB_TOKEN"
    default_org: "acme"
  gitlab:
    enabled: false
    base_url: "https://gitlab.com"
    token_env: "OPSINTEL_GITLAB_TOKEN"
  jenkins:
    enabled: false
    base_url: "https://jenkins.example.com"
    user: "opsintel-bot"
    token_env: "OPSINTEL_JENKINS_TOKEN"
  sonar:
    enabled: false
    base_url: "https://sonarqube.example.com"
    token_env: "OPSINTEL_SONAR_TOKEN"
    project_key_prefix: "acme_" # prepended to short project keys

# ─────────────────────────────────────────────
# Teams (company / squad-specific rules)
# ─────────────────────────────────────────────
# Every *.md file under teams.dir/<active>/ is merged into the system
# prompt. Start from the shipped `teams/example-team/` template.
teams:
  active: "example-team"
  dir: "~/.opsintelligence/teams"

# ─────────────────────────────────────────────
# Channels — enterprise only (Slack + REST/WS gateway)
# ─────────────────────────────────────────────
channels:
  outbound:
    max_attempts: 5
    base_delay_ms: 250
    max_delay_ms: 10000
    jitter_percent: 0.2
    breaker_threshold: 5
    breaker_cooldown_s: 30
    dlq_path: "~/.opsintelligence/channels/dlq.ndjson"
  # Same channel adapters as AssistClaw — enable any subset:
  # telegram:
  #   bot_token: "${OPSINTEL_TELEGRAM_BOT_TOKEN}"
  #   dm_mode: "pairing"
  #   require_mention: true
  #   allow_from: []
  # discord:
  #   bot_token: "${OPSINTEL_DISCORD_BOT_TOKEN}"
  #   dm_mode: "pairing"
  #   require_mention: true
  #   allow_from: []
  slack:
    bot_token: "${OPSINTEL_SLACK_BOT_TOKEN}"
    app_token: "${OPSINTEL_SLACK_APP_TOKEN}" # xapp-... for Socket Mode
    dm_mode: "pairing"
    allow_from: [] # Slack user IDs or handles; empty = any member of workspace
  # whatsapp:
  #   session_id: "personal"
  #   dm_mode: "pairing"
  #   allow_from: []

# ─────────────────────────────────────────────
# Cron — scheduled prompts (heartbeat sweep, SLA checks, etc.)
# ─────────────────────────────────────────────
# The agent reads HEARTBEAT.md from state_dir on each "heartbeat" tick.
cron:
  - id: "heartbeat-morning"
    schedule: "0 9 * * 1-5" # 09:00 local, Mon-Fri
    prompt: "heartbeat"
  - id: "ci-sweep-hourly"
    schedule: "0 * * * *"
    prompt: "Check CI health across configured platforms (devops.github.workflow_runs, devops.gitlab.pipelines, devops.jenkins.job). If any required main-branch pipeline is red, post a concise summary to the #ops-alerts Slack channel. Otherwise respond HEARTBEAT_OK."
  - id: "sonar-gate-daily"
    schedule: "0 8 * * 1-5"
    prompt: "Run devops.sonar.quality_gate for each project under devops.sonar.project_key_prefix. Report any flips OK → WARN/ERROR since yesterday. If all green, respond HEARTBEAT_OK."

# ─────────────────────────────────────────────
# Webhooks — incoming events from GitHub / GitLab / Jenkins
# ─────────────────────────────────────────────
# Expose the webhook endpoint via the gateway:
#   https://<gateway-host>:<port>/api/webhook/<path>
# Configure each platform to POST to the corresponding path with the
# shared secret in X-OpsIntelligence-Token.
webhooks:
  enabled: true
  # Shared-secret token for the *legacy generic mappings* below
  # (X-OpsIntelligence-Token header). Adapters do their own
  # verification (HMAC, mTLS, …) and ignore this field.
  token: "${OPSINTEL_WEBHOOK_TOKEN}"

  # Router-level knobs shared by every adapter. Saturation returns 503 +
  # Retry-After so the sending platform retries with its own backoff
  # instead of this process fanning goroutines unbounded.
  max_concurrent: 10
  timeout: "10m"

  # ── Typed webhook adapters (preferred) ────────────────────────────
  # Each adapter lives under internal/webhookadapter/<name>/ and knows
  # how to verify, parse, filter, and render events from its platform.
  # Adapters take precedence over the generic mappings below; add a new
  # one by dropping a new package under internal/webhookadapter/ and
  # wiring it in cmd/opsintelligence/main.go#buildWebhookAdapterRegistry.
  adapters:
    # GitHub webhook adapter
    # Point a repository / organisation webhook at
    #   https://<your-host>/api/webhook/github
    # with Content-Type: application/json and the secret below.
    # The adapter validates X-Hub-Signature-256 HMAC, parses
    # X-GitHub-Event, filters by (event, action), passes the full
    # nested JSON to the prompt template, and the gateway responds
    # 202 Accepted — the agent runs asynchronously so GitHub's
    # 10-second delivery timeout is never hit. See
    # doc/github-webhooks.md and doc/webhook-adapters.md for full
    # reference.
    github:
      enabled: true
      secret: "${OPSINTEL_GITHUB_WEBHOOK_SECRET}"
      path: "github"          # full URL: /api/webhook/github
      # events + actions allowlist. Empty map = allow all events.
      # Empty action list for an entry = allow all actions of that event.
      events:
        pull_request:        [opened, reopened, synchronize, ready_for_review, edited]
        pull_request_review: [submitted]
        workflow_run:        [completed]
        check_suite:         [completed]
        issues:              [opened, reopened]
        push:                []   # no-action event
      # Per-event prompt templates. Templates use Go text/template and
      # have access to the *full* parsed payload. In addition, the
      # adapter injects:
      #   {{.event}}        — X-GitHub-Event value
      #   {{.delivery_id}}  — X-GitHub-Delivery value
      #   {{.action}}       — payload.action (may be empty)
      #   {{.payload_keys}} — comma-separated top-level keys (debug)
      # Missing templates fall back to default_prompt, then a concise
      # built-in auto-summary.
      prompts:
        pull_request: |
          GitHub PR {{.action}}: {{.repository.full_name}}#{{.pull_request.number}}
          — "{{.pull_request.title}}" by @{{.pull_request.user.login}}
          Base: {{.pull_request.base.ref}} ← Head: {{.pull_request.head.ref}}

          Run `chain_run id="pr-review"` with owner/repo/number above.
          You may dispatch sub-tasks with `subagent_run_async` /
          `subagent_run_parallel` to check Sonar + pipeline in parallel.
          Post the verdict back via the gh-pr-review skill.
        workflow_run: |
          CI run "{{.workflow_run.name}}" finished with
          conclusion={{.workflow_run.conclusion}} on
          {{.repository.full_name}} branch {{.workflow_run.head_branch}}.
          If conclusion is failure|cancelled|timed_out, run
          `chain_run id="cicd-regression"`; otherwise acknowledge briefly.
        check_suite: |
          Check suite {{.check_suite.conclusion}} on
          {{.repository.full_name}} for SHA {{.check_suite.head_sha}}.
          Investigate failing runs via devops.github.workflow_logs.
        issues: |
          Issue {{.action}}: {{.repository.full_name}}#{{.issue.number}}
          — "{{.issue.title}}" by @{{.issue.user.login}}. Triage and
          label per team conventions.

    # Future adapters (stubs — enable when packages land):
    # gitlab:
    #   enabled: false
    #   token: "${OPSINTEL_GITLAB_WEBHOOK_TOKEN}"
    #   events: [merge_request, pipeline, push]
    # bitbucket:
    #   enabled: false
    #   secret: "${OPSINTEL_BITBUCKET_WEBHOOK_SECRET}"

  # ── Legacy generic webhook mappings (still supported) ──────────────
  # For ad-hoc receivers that don't have a typed adapter yet (Zapier,
  # n8n, custom scripts). Templates only see top-level JSON keys via
  # {{.key}} — for nested payloads, write a proper adapter instead.
  # Protected by the global `token` above (X-OpsIntelligence-Token).
  mappings:
    # ── GitLab ────────────────────────────────────────────────────────
    # GitLab payloads expose top-level `object_kind` (e.g.
    # "merge_request", "pipeline").
    - path: "gitlab"
      prompt_template: |
        GitLab webhook fired: object_kind={{.object_kind}}.

        Rules:
        - For object_kind=merge_request with action opened/update,
          follow [[pr-review]] and post a verdict.
        - For object_kind=pipeline with status=failed on the default
          branch, follow [[cicd]] and post the first failing job.
        - Otherwise, acknowledge with a one-line status.
      deliver: true
      channel: "slack"
      to: "#ops-alerts"
    # ── Jenkins ───────────────────────────────────────────────────────
    # Configure the "Notification" plugin to POST build status JSON.
    # Top-level keys typically include `name`, `url`, and nested `build`.
    - path: "jenkins"
      prompt_template: |
        Jenkins notification fired for job {{.name}} ({{.url}}).

        Rules:
        - Call devops.jenkins.build for the latest build of this job.
        - If the result is FAILURE or UNSTABLE on the default branch,
          follow [[cicd]] and post the first failing step.
        - Otherwise, acknowledge with a one-line status.
      deliver: true
      channel: "slack"
      to: "#ops-alerts"

# ─────────────────────────────────────────────
# MCP — plug in observability / ticketing / extra platforms
# ─────────────────────────────────────────────
# Anything not first-class (PagerDuty, Datadog, Sentry, Jira, Grafana,
# Azure DevOps, Bitbucket, Terraform Cloud, …) should come in via MCP.
mcp:
  server:
    enabled: false
  clients: []
    # - name: sentry
    #   transport: stdio
    #   command: npx
    #   args: ["-y", "@sentry/mcp-server"]

# ─────────────────────────────────────────────
# Multi-model routing
# ─────────────────────────────────────────────
routing:
  default: "anthropic/claude-3-5-haiku-20241022"
  fallback: "ollama/llama3.2"
  rules:
    - task: "code"
      model: "anthropic/claude-3-7-sonnet-20250219"
    - task: "review"
      model: "anthropic/claude-3-7-sonnet-20250219"

# ─────────────────────────────────────────────
# Memory
# ─────────────────────────────────────────────
memory:
  working_token_budget: 100000
  semantic_backend: "sqlite_vec"
  mining:
    enabled: false
    mode: "incremental"
    include:
      - "MEMORY.md"
      - "memory/*.md"
    exclude:
      - "memory/archive/*"
    chunk_size: 512
    chunk_overlap: 64
    max_file_size_kb: 512
    max_files_per_run: 1000
    state_path: "~/.opsintelligence/memory/mining_state.json"

# ─────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────
embeddings:
  priority:
    - "openai"
    - "ollama"

# ─────────────────────────────────────────────
# Ops-plane datastore (users, RBAC, audit, tasks)
#
# This is STRICTLY SEPARATE from agent memory (memory.episodic_db_path /
# memory.semantic_db_path). Local installs keep the default SQLite file
# under state_dir/ops.db; cloud installs point at Postgres.
# ─────────────────────────────────────────────
datastore:
  # driver: "sqlite" (default) | "postgres"
  driver: "sqlite"
  # dsn: driver-specific. Empty -> file:<state_dir>/ops.db?_foreign_keys=on.
  # The OPSINTELLIGENCE_DATASTORE_DSN env var overrides this value.
  #
  # Postgres example:
  #   driver: "postgres"
  #   dsn: "postgres://opsi:secret@db.internal:5432/opsi?sslmode=require"
  dsn: ""
  max_open_conns: 0
  max_idle_conns: 0
  conn_max_lifetime: ""
  # migrations: "auto" (run on startup) | "manual" (only via
  # `opsintelligence datastore migrate`). Default auto.
  migrations: "auto"

# ─────────────────────────────────────────────
# Auth (identity + session for the HTTP gateway + dashboard)
#
# Defaults shown below are safe for a local install on http://127.0.0.1:
# local password login on, API keys on, OIDC off, CSRF on, Secure
# cookies tracked from gateway TLS, legacy shared token empty.
#
# Every knob here can also be driven from the dashboard Settings UI
# (phase 3c). CLI and UI call the same shared configsvc layer.
# ─────────────────────────────────────────────
auth:
  local:
    enabled: true
    min_password_length: 12       # hard floor of 8
    require_mixed_case: false
    require_digit: false
    require_symbol: false
  api_keys:
    enabled: true
    # default_expiry: Go duration string (e.g. "720h"). Empty = never.
    default_expiry: ""
    # max_expiry caps user-supplied --expires. Empty = uncapped.
    max_expiry: ""
  sessions:
    cookie_name: "opi_session"
    csrf_cookie_name: "opi_csrf"
    path: "/"
    domain: ""
    # secure: auto-tracks gateway.tls.cert when unset. Force true in prod.
    # secure: true
    same_site: "lax"              # lax | strict | none
    ttl: "168h"                   # 7 days idle timeout
  csrf:
    enabled: true
  oidc:
    enabled: false
    # issuer: "https://accounts.google.com"
    # client_id: "..."
    # client_secret: "${OPSINTELLIGENCE_OIDC_CLIENT_SECRET}"
    # redirect_url: "https://opi.example.com/api/v1/auth/oidc/callback"
    scopes: []                    # default: [openid, profile, email]
    username_claim: ""            # default: preferred_username
    email_claim: ""               # default: email
    allowed_domains: []
    default_role: ""              # default: viewer
  # legacy_shared_token is the pre-RBAC bootstrap credential. Inherits
  # OPSINTELLIGENCE_GATEWAY_TOKEN when unset. Prefer issuing API keys.
  legacy_shared_token: ""
  allow_anonymous_bootstrap: true # auto-disabled after first user

# ─────────────────────────────────────────────
# Tracing (off by default)
# ─────────────────────────────────────────────
tracing:
  enabled: false
  otlp_endpoint: "localhost:4317"
  service_name: "opsintelligence"
  sample_ratio: 0.01

# ─────────────────────────────────────────────
# LLM providers
# ─────────────────────────────────────────────
providers:
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
  openai:
    api_key: "${OPENAI_API_KEY}"
  ollama:
    base_url: "http://127.0.0.1:11434"
    default_model: "llama3.2"
  groq:
    api_key: "${GROQ_API_KEY}"
  openrouter:
    api_key: "${OPENROUTER_API_KEY}"
